{
	admin off
	persist_config off
	auto_https off

	log {
		format json
	}

	servers {
		trusted_proxies static private_ranges 100.0.0.0/8
	}
}

:{$PORT:80} {
	log {
		format json
	}

	respond /health 200

	# Security headers
	header {
		X-Content-Type-Options "nosniff"
		-Server
	}

	# Default: always revalidate (SPA routes, index.html, etc.)
	header Cache-Control "no-cache"

	# Hashed assets (JS, CSS, fonts, images) — immutable, cache forever
	# Vite outputs all hashed files to /assets/ with content hashes in filenames
	@hashed_assets path /assets/*
	header @hashed_assets Cache-Control "public, max-age=31536000, immutable"

	root * {{.DIST_DIR}}

	encode {
		gzip
		zstd
	}

	# Static assets — 404 if missing, don't fall through to SPA
	handle /assets/* {
		file_server {
			hide .git
			hide .env*
		}
	}

	# SPA routing for everything else
	handle {
		try_files {path} {path}.html {path}/index.html /index.html
		file_server {
			hide .git
			hide .env*
		}
	}
}
