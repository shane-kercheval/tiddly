# =============================================================================
# Bookmarks Application Configuration
# Copy this file to .env and update values for your environment.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
POSTGRES_USER=bookmarks
POSTGRES_PASSWORD=bookmarks
POSTGRES_DB=bookmarks

# Host ports the local Docker stack (Postgres + Redis) binds on your machine.
# Defaults match the original single-stack setup, so nothing changes if you
# leave them alone. Override them — together with COMPOSE_PROJECT_NAME below —
# when running multiple git worktrees at once, so each worktree gets its own
# isolated stack instead of colliding on the same host ports. DATABASE_URL and
# REDIS_URL below reference these, so changing the port here updates both.
# See README → "Running multiple worktrees concurrently".
POSTGRES_HOST_PORT=5435
REDIS_HOST_PORT=6379

DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_HOST_PORT}/${POSTGRES_DB}
REDIS_URL=redis://localhost:${REDIS_HOST_PORT}

# Docker Compose project name — namespaces containers/volumes/networks. Defaults
# to the directory name, so separate worktrees are already isolated by default;
# set it explicitly only if you want a stable, predictable name per worktree.
# COMPOSE_PROJECT_NAME=tiddly-main

# Connection pool settings (optional, defaults shown)
# See docs/connection-pool-tuning.md for sizing rationale
# DB_POOL_SIZE=10       # Persistent connections per worker
# DB_MAX_OVERFLOW=10    # Additional temporary connections per worker
# DB_POOL_RECYCLE=3600  # Recycle connections older than 1 hour
# REDIS_POOL_SIZE=5     # Redis connections per worker

# -----------------------------------------------------------------------------
# Workers
# -----------------------------------------------------------------------------
# Number of uvicorn worker processes (used in Dockerfile)
# API_WORKERS=4         # Set in Railway Variables tab

# -----------------------------------------------------------------------------
# Auth0 (used by both backend and frontend)
# Get these from: Auth0 Dashboard -> Applications -> Your App -> Settings
# Leave empty for dev mode (no authentication required)
# -----------------------------------------------------------------------------
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=

# -----------------------------------------------------------------------------
# Backend Settings
# -----------------------------------------------------------------------------
# CORS: Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173

# Auth0 custom claim namespace for reading email/email_verified from access tokens
# This URL prefix is used to extract namespaced claims (e.g., {namespace}/email)
# The URL does not need to resolve — it's just a unique prefix
# Required when VITE_DEV_MODE=false
AUTH0_CUSTOM_CLAIM_NAMESPACE=https://tiddly.me

# -----------------------------------------------------------------------------
# Clerk (dual-accept window — Auth0 → Clerk migration)
# Frontend API domain of the Clerk instance: "clerk.tiddly.me" in production,
# "<slug>.clerk.accounts.dev" for a development instance (Dashboard -> API Keys).
# Required when VITE_DEV_MODE=false.
# -----------------------------------------------------------------------------
CLERK_FRONTEND_API=
# Comma-separated web origins accepted as the `azp` claim on Clerk session
# tokens (Clerk tokens carry no audience). Required when VITE_DEV_MODE=false.
# Production: https://tiddly.me — local real-auth testing: http://localhost:5173
CLERK_AUTHORIZED_PARTIES=
# Per-issuer JIT user-creation flags (dual-accept window rules; removed at
# decommission). Lookup always works; these gate creation of new user rows.
# CLERK_JIT_CREATE_ENABLED=false   # production: off until M6a's import reconciles
# AUTH0_JIT_CREATE_ENABLED=true    # production: turned off at M6a's flip

# -----------------------------------------------------------------------------
# Shared Settings (VITE_ prefix exposes to frontend)
# -----------------------------------------------------------------------------
# Development mode: bypasses auth, uses fake dev user
# Set to true for local development without Auth0
VITE_DEV_MODE=false

# API URL for frontend and MCP server to connect to backend
VITE_API_URL=http://localhost:8000

# Frontend URL (used by backend for consent error messages)
VITE_FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# LLM Provider API Keys (for AI features)
# At minimum, set the key for the default model's provider (Gemini for suggestions)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# MCP Servers (Model Context Protocol for AI agents)
# -----------------------------------------------------------------------------
# Content MCP Server (bookmarks and notes)
MCP_HOST=0.0.0.0
MCP_PORT=8001

# Prompt MCP Server
PROMPT_MCP_HOST=0.0.0.0
PROMPT_MCP_PORT=8002

# MCP URLs for frontend to display in setup instructions
# In production, set to your deployed MCP server URLs
VITE_MCP_URL=http://localhost:8001
VITE_PROMPT_MCP_URL=http://localhost:8002

# -----------------------------------------------------------------------------
# Security Testing (Optional - for live penetration tests)
# -----------------------------------------------------------------------------
# These are only needed to run: make pen_tests
# Tests are automatically skipped if these are not set (safe for CI/CD).
#
# Setup:
# 1. Create two separate test users in Auth0 Dashboard (User Management -> Users)
#    - e.g., security-test-a@fake.local, security-test-b@fake.local
# 2. Log into your app as each user and create a PAT (Personal Access Token)
# 3. Paste the tokens below
#
# IMPORTANT: The two PATs MUST be from DIFFERENT user accounts!
#
# SECURITY_TEST_API_URL=https://tiddly.me/
# SECURITY_TEST_USER_A_PAT=bm_your_first_user_token
# SECURITY_TEST_USER_B_PAT=bm_your_second_user_token
